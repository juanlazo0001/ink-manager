// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  OWNER
  FRONT_DESK
  ARTIST
  CUSTOMER
}

enum AppointmentStatus {
  REQUESTED
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum Channel {
  EMAIL
  INSTAGRAM
  FACEBOOK
  // Front desk logging a walk-in or phone-call inquiry on the customer's
  // behalf (see StaffInquiryForm) -- never selectable on the public intake
  // form, which is always self-reported by the customer.
  PHONE
}

enum GiftCardStatus {
  ACTIVE
  REDEEMED
  EXPIRED
  VOID
  EXEMPT
}

enum LiabilityWaiverStatus {
  PENDING
  SIGNED
  VERIFIED
}

enum ConversationType {
  CLIENT
  STAFF
  GROUP
}

enum MessageChannel {
  IN_APP
  SMS
  EMAIL
  INSTAGRAM
  FACEBOOK
  PHONE
  OTHER
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

// Phase 7B: every channel a studio could eventually self-serve connect.
// Only SMS (Twilio) is actually wired up to a real provider this phase --
// the others exist so Settings -> Integrations can show them as "Coming
// soon" cards on the same chassis rather than a Twilio-shaped one-off.
enum IntegrationChannel {
  SMS
  EMAIL
  INSTAGRAM
  FACEBOOK
  GOOGLE_CALENDAR
}

enum IntegrationStatus {
  NOT_CONNECTED
  CONNECTED
  ERROR
}

enum JobStatus {
  RUNNING
  SUCCEEDED
  FAILED
}

enum InquiryStatus {
  NEW
  ARTIST_ASSIGNED
  AWAITING_CLIENT_RESPONSE
  BUDGET_NEGOTIATION
  SCHEDULING
  WAITLISTED
  DEPOSIT_PENDING
  CONFIRMED
  CLOSED_LOST
  COLD_LEAD
}

model Studio {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  logoUrl   String?
  website   String?
  createdAt DateTime @default(now())

  users              User[]
  clients            Client[]
  appointments       Appointment[]
  locations          Location[]
  rolePermissions    RolePermission[]
  inquiries          Inquiry[]
  auditLogs          AuditLog[]
  giftCards          GiftCard[]
  settings           StudioSettings?
  liabilityWaivers   LiabilityWaiver[]
  taskDismissals     TaskDismissal[]
  personalTasks      PersonalTask[]
  sectionSeens       SectionSeen[]
  conversations      Conversation[]
  messages           Message[]
  conversationTags   ConversationTag[]
  prefillDrafts      PrefillDraft[]
  integrations       StudioIntegration[]
  artistReminderLogs ArtistReminderLog[]
  dismissedDuplicatePairs DismissedDuplicatePair[]
  customPolicies     CustomPolicy[]
}

// Self-serve provider connections -- a studio owner connects their OWN
// Twilio (etc.) account from Settings -> Integrations, rather than the
// platform holding one shared set of provider credentials for every
// studio. encryptedSecret is AES-256-GCM ciphertext (see lib/secrets.ts),
// decrypted only server-side at send/receive time -- no route ever
// returns it, only masked display values. metadata is deliberately
// separate from encryptedSecret: non-secret config an inbound webhook
// needs to route by (e.g. the studio's own Twilio phone number), safe to
// read back to the client as-is.
model StudioIntegration {
  id              String             @id @default(cuid())
  channel         IntegrationChannel
  status          IntegrationStatus  @default(NOT_CONNECTED)
  displayName     String?
  encryptedSecret String?
  metadata        Json?
  lastError       String?
  connectedAt     DateTime?
  updatedAt       DateTime           @updatedAt

  studioId String
  studio   Studio @relation(fields: [studioId], references: [id])

  @@unique([studioId, channel])
}

model RolePermission {
  id            String  @id @default(cuid())
  role          Role
  permissionKey String
  allowed       Boolean @default(false)

  studioId String
  studio   Studio @relation(fields: [studioId], references: [id])

  @@unique([studioId, role, permissionKey])
}

model Location {
  id        String   @id @default(cuid())
  name      String
  address   String?
  phone     String?
  email     String?
  hours     Json?
  createdAt DateTime @default(now())

  studioId String
  studio   Studio @relation(fields: [studioId], references: [id])

  users User[]

  @@index([studioId])
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  phone     String?
  avatarUrl String?
  role      Role
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  studioId String
  studio   Studio @relation(fields: [studioId], references: [id])

  artist Artist?
  client Client?

  auditLogs               AuditLog[]
  issuedGiftCards         GiftCard[]
  verifiedWaivers         LiabilityWaiver[]         @relation("WaiverVerifiedBy")
  checkedOutAppointments  Appointment[]             @relation("AppointmentCheckedOutBy")
  taskDismissals          TaskDismissal[]
  personalTasks           PersonalTask[]
  createdPersonalTasks    PersonalTask[]            @relation("PersonalTaskCreatedBy")
  sectionSeens            SectionSeen[]
  staffConversation       Conversation?             @relation("StaffConversation")
  authoredMessages        Message[]                 @relation("MessageAuthor")
  conversationReads       ConversationRead[]
  conversationParticipant ConversationParticipant[]
  createdConversationTags ConversationTag[]
  createdPrefillDrafts    PrefillDraft[]
  dismissedDuplicatePairs DismissedDuplicatePair[]

  locationId String?
  location   Location? @relation(fields: [locationId], references: [id])

  @@index([studioId])
}

model Artist {
  id              String   @id @default(cuid())
  bio             String?
  specialties     String[]
  portfolioImages String[]

  // Manual, staff-entered links only -- no automatic profile/photo/bio
  // import from Instagram or Facebook this pass. That would need the same
  // Meta Business API + App Review process already planned for the
  // client-facing channel integration (Phase 7B); doing it here ahead of
  // that would mean either a scraper (unreliable, likely ToS-violating) or
  // duplicate integration work later.
  instagramHandle    String?
  facebookProfileUrl String?

  // Advisory weekly availability, not enforced (same philosophy as the
  // scheduling buffer warning -- it informs staff, doesn't block them).
  // Shape: Array<{ dayOfWeek: 0-6 (0 = Sunday), startTime: "HH:MM", endTime: "HH:MM" }>
  preferredSchedule Json?

  // Guest artist window -- both nullable/independent of isGuest so a guest
  // can be flagged before dates are picked. Visibility rules (default-
  // hidden past guestEndDate, reachable via a filter toggle) live on
  // Calendar and assignment pickers, not here; this tab always shows guests
  // regardless of window.
  isGuest        Boolean   @default(false)
  guestStartDate DateTime?
  guestEndDate   DateTime?

  userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  appointments       Appointment[]
  preferredInquiries Inquiry[]           @relation("PreferredArtist")
  assignedInquiries  Inquiry[]           @relation("AssignedArtist")
  reminderLogs       ArtistReminderLog[]
}

model Client {
  id        String   @id @default(cuid())
  firstName String
  lastName  String
  email     String?
  phone     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Manual, staff-entered links only -- same rationale as Artist's
  // identical fields (see Artist.instagramHandle): no automatic
  // profile/photo import from Instagram or Facebook this pass.
  instagramHandle    String?
  facebookProfileUrl String?
  // Free-text catch-all for any other contact channel not worth a
  // dedicated column (TikTok, personal website, etc.) -- informational
  // display only, no validation beyond basic length.
  otherContact String?

  studioId String
  studio   Studio @relation(fields: [studioId], references: [id])

  userId String? @unique
  user   User?   @relation(fields: [userId], references: [id])

  // A client with this set is considered merged/inactive; the surviving
  // client is the one at mergedIntoId. Exclude these from list views.
  mergedIntoId String?
  mergedInto   Client?  @relation("ClientMerge", fields: [mergedIntoId], references: [id])
  mergedFrom   Client[] @relation("ClientMerge")

  // Soft, reversible hide -- same exclude-from-list-views pattern as
  // mergedIntoId above, but fully intact and unarchivable, unlike a merge.
  archivedAt DateTime?

  // Phase 7B: set when this client texts STOP/UNSUBSCRIBE/CANCEL/QUIT to
  // the studio's connected SMS number, cleared on START/UNSTOP. Checked
  // server-side before every outbound SMS send regardless of what the UI
  // shows -- this is the actual enforcement point, not just a display flag.
  smsOptedOutAt DateTime?

  // A2P 10DLC compliance: affirmative, opt-in consent, not just "they gave
  // us a phone number." Set once, the first time it's actually given (the
  // public intake form's required, unchecked-by-default checkbox is the
  // only source today -- smsConsentSource records which flow, so a future
  // second source doesn't have to guess). Never overwritten once set --
  // a returning client's original consent timestamp is preserved across
  // every later submission, staff or public.
  smsConsentGivenAt DateTime?
  smsConsentSource  String?

  appointments     Appointment[]
  consentForms     ConsentForm[]
  inquiries        Inquiry[]
  giftCards        GiftCard[]
  liabilityWaivers LiabilityWaiver[]
  conversation     Conversation?
  phones           ClientPhone[]
  emails           ClientEmail[]

  @@index([studioId])
  @@index([studioId, createdAt])
}

// Additive secondary-contact layer -- Client.phone stays the "primary"
// scalar field every existing consumer (intake form, waivers, duplicate
// detection, PhoneInput default) keeps reading unchanged. These tables
// exist purely so a client can have more than one phone/email on file;
// the row with isPrimary: true always mirrors Client.phone exactly (kept
// in sync by lib/clientContacts.ts, never diverges from it).
model ClientPhone {
  id        String   @id @default(cuid())
  phone     String
  label     String?
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())

  clientId String
  client   Client @relation(fields: [clientId], references: [id])

  @@unique([clientId, phone])
}

model ClientEmail {
  id        String   @id @default(cuid())
  email     String
  label     String?
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())

  clientId String
  client   Client @relation(fields: [clientId], references: [id])

  @@unique([clientId, email])
}

// Suppresses an automatic potential-duplicate suggestion for one specific
// pair -- staff decided these two clients are NOT the same person. Manual
// merge via the client-search picker stays available regardless (this only
// hides the pair from GET /clients/:id/potential-duplicates), since staff
// might reconsider later. clientAId/clientBId are always stored with the
// lexicographically smaller id first, so a pair is unique and matchable
// regardless of which of the two clients the dismiss action was fired from.
model DismissedDuplicatePair {
  id          String   @id @default(cuid())
  clientAId   String
  clientBId   String
  dismissedAt DateTime @default(now())

  studioId String
  studio   Studio @relation(fields: [studioId], references: [id])

  dismissedById String
  dismissedBy   User   @relation(fields: [dismissedById], references: [id])

  @@unique([clientAId, clientBId])
  @@index([studioId])
}

model Appointment {
  id          String            @id @default(cuid())
  startTime   DateTime
  endTime     DateTime
  status      AppointmentStatus @default(REQUESTED)
  depositPaid Boolean           @default(false)
  notes       String?
  createdAt   DateTime          @default(now())

  // Soft, reversible hide -- same exclude-from-list-views pattern as
  // Client.archivedAt / Inquiry.archivedAt. The record stays intact and
  // directly reachable via GET /:id; only the default list (which backs the
  // Calendar) excludes it.
  archivedAt DateTime?

  // Checkout (Phase 4): filled in together, at the end of the session, by
  // POST /appointments/:id/checkout. status moves to COMPLETED at the same
  // time -- COMPLETED already existed as a plain manual status option with
  // no other logic attached to it, so checkout formalizes what that value
  // already meant rather than repurposing something with different meaning.
  finalCostCents Int?
  closeoutNotes  String?
  checkedOutAt   DateTime?
  checkedOutById String?
  checkedOutBy   User?     @relation("AppointmentCheckedOutBy", fields: [checkedOutById], references: [id])

  // Phase 7B-2: per-appointment dedup for the client reminder cadence (one
  // week before, night before, morning of) -- each is set once its own
  // reminder actually sends, so the ticker never double-sends the same
  // reminder type for the same appointment across multiple 15-minute ticks.
  reminderWeekSentAt        DateTime?
  reminderNightBeforeSentAt DateTime?
  reminderMorningOfSentAt   DateTime?

  studioId String
  studio   Studio @relation(fields: [studioId], references: [id])

  artistId String
  artist   Artist @relation(fields: [artistId], references: [id])

  clientId String
  client   Client @relation(fields: [clientId], references: [id])

  // One project (Inquiry) has many sessions (Appointment) -- distinct from
  // Inquiry.appointmentId below, which is the older 1:1 "scheduled slot"
  // link from the original scheduling flow. Required as of Phase 3: both
  // appointment-creation routes (standalone and /inquiries/:id/schedule)
  // now populate it, and every appointment must have one.
  inquiryId      String
  inquiryProject Inquiry @relation("InquirySessions", fields: [inquiryId], references: [id])

  consentForm     ConsentForm?
  inquiry         Inquiry?         @relation("InquiryScheduledAppointment")
  giftCard        GiftCard?
  liabilityWaiver LiabilityWaiver?

  @@index([studioId, startTime])
  @@index([inquiryId])
  @@index([studioId, createdAt])
  @@index([artistId, createdAt])
}

model ConsentForm {
  id            String    @id @default(cuid())
  signedAt      DateTime?
  signatureData String?
  createdAt     DateTime  @default(now())

  signingToken   String?   @unique
  tokenExpiresAt DateTime?

  clientId String
  client   Client @relation(fields: [clientId], references: [id])

  appointmentId String?      @unique
  appointment   Appointment? @relation(fields: [appointmentId], references: [id])
}

model Inquiry {
  id                    String        @id @default(cuid())
  channel               Channel
  description           String
  colorOrBlackGrey      String
  placement             String
  estimatedSize         String
  hasBeenTattooedBefore Boolean
  budget                String?
  desiredTiming         String?
  referenceImages       String[]
  placementImages       String[]
  status                InquiryStatus @default(NEW)
  priceEstimateLow      Float?
  priceEstimateHigh     Float?
  // Deprecated: superseded by timeEstimateHoursMin/Max below, which make
  // the time estimate a real range (consistent with the price range) --
  // kept for historical rows, no longer written to by any route.
  timeEstimateHours     Float?
  timeEstimateHoursMin  Float?
  timeEstimateHoursMax  Float?
  declineNote           String?
  createdAt             DateTime      @default(now())
  // Phase 7A: didn't exist before this phase. Added specifically as one of
  // the four last-activity signals the cold-lead sweep considers (see
  // lib/jobs/coldLeadSweep.ts) -- Prisma maintains it automatically on
  // every update() call, no route needs to set it explicitly.
  updatedAt             DateTime      @updatedAt
  assignedAt            DateTime?

  estimateToken          String?   @unique
  estimateTokenExpiresAt DateTime?
  estimateSentAt         DateTime?
  estimateOpenedAt       DateTime?
  estimateRespondedAt    DateTime?
  // Phase 7B-2: set once the 24-hour-after-opened follow-up text actually
  // sends. Reset to null wherever estimateOpenedAt/estimateRespondedAt
  // already get reset on a resend (POST /:id/send-estimate) -- a resent
  // estimate is a new estimate event, and the old follow-up shouldn't
  // block a fresh one from ever firing again.
  estimateFollowUpSentAt DateTime?
  // The studio's estimate T&C text exactly as it was when this estimate was
  // sent, so a later edit to StudioSettings.estimateTerms never retroactively
  // changes what a client already saw/agreed to.
  estimateTermsSnapshot  String?
  clientStatedBudget     String?
  closedReason           String?
  // Phase 7A: set only by POST /:id/mark-lost (a deliberate staff action),
  // distinct from closedReason above which predates this phase and is left
  // untouched. Cleared by /:id/reopen. Not set by the cold-lead sweep --
  // that path is fully automated and has no human-entered reason.
  lostReason             String?
  lostAt                 DateTime?

  // Free-text staff notes -- internal only, never shown to the client or
  // included in the artist share projection. Same plain single-field
  // pattern as Appointment.notes/PersonalTask.notes elsewhere in this
  // schema, not a timestamped log.
  notes String?

  // Soft, reversible hide -- same pattern as Client.archivedAt.
  archivedAt DateTime?

  studioId String
  studio   Studio @relation(fields: [studioId], references: [id])

  clientId String
  client   Client @relation(fields: [clientId], references: [id])

  preferredArtistId String?
  preferredArtist   Artist? @relation("PreferredArtist", fields: [preferredArtistId], references: [id])

  assignedArtistId String?
  assignedArtist   Artist? @relation("AssignedArtist", fields: [assignedArtistId], references: [id])

  // Older 1:1 "scheduled slot" link from the original scheduling flow.
  appointmentId String?      @unique
  appointment   Appointment? @relation("InquiryScheduledAppointment", fields: [appointmentId], references: [id])

  // Newer 1:many "sessions under this project" link -- see Appointment.inquiryId.
  sessions Appointment[] @relation("InquirySessions")

  depositForm DepositForm?

  @@index([studioId])
  @@index([studioId, status])
  @@index([clientId])
  @@index([studioId, createdAt])
  @@index([assignedArtistId, createdAt])
}

model StudioSettings {
  id                            String   @id @default(cuid())
  refundPolicy                  String?
  depositPolicy                 String?
  reschedulePolicy              String?
  communicationPolicy           String?
  estimateFollowUpHours         Int      @default(24)
  estimateTerms                 String?
  giftCardDefaultExpirationDays Int?
  calendarInviteTemplate        String?
  // A2P 10DLC compliance: public, unauthenticated /privacy/:studioSlug and
  // /terms/:studioSlug pages render these (sanitized, same as every other
  // HTML policy field here). Not legal advice -- the seeded default text is
  // a reasonable starting point flagged for a lawyer's review, same caveat
  // as every other policy field in this app.
  privacyPolicy                 String?
  termsAndConditions            String?
  // Phase 7A: daily jobs (gift-card expiration, cold-lead sweep) compute
  // "the day" per-studio using this rather than the server process's own
  // TZ. IANA identifier (e.g. "America/New_York"). Also reserved for the
  // next phase's SMS send-window computation.
  timezone                      String   @default("America/New_York")
  // Phase 7A: days of no activity (see coldLeadSweep.ts's last-activity
  // definition) before a pre-conversion inquiry is auto-marked COLD_LEAD.
  coldLeadDays                  Int      @default(90)
  // Conversation composer templates (Phase 6A). Array<{ id: string, name: string, body: string }>.
  messageTemplates              Json?
  // Liability waiver template (Phase 4), editable by OWNER from Settings.
  // Array<{ question: string, type: "yes_no" | "yes_no_explain", explainPrompt?: string }>
  waiverHealthQuestions         Json?
  // Array<string>, exactly 10 clauses in display/initialing order.
  waiverClauses                 Json?
  waiverAcknowledgment          String?
  waiverPhotoRelease            String?
  // UI-1 §7: sidebar new-item count bubbles (Phase 5's SectionSeen-driven
  // badges) are opt-in, default off. When false, the frontend neither
  // renders bubbles nor fires POST /nav-counts/seen -- doesn't affect the
  // conversations unread badge (ConversationRead-driven) or the Tasks
  // top-bar badge, both unconditional.
  showSidebarBadges             Boolean  @default(false)
  // Calendar grey-shading (studio-closed source). Same shape family as
  // Artist.preferredSchedule, one entry per weekday.
  // Array<{ dayOfWeek: 0-6 (0 = Sunday), isOpen: boolean, openTime?: "HH:MM", closeTime?: "HH:MM" }>
  // Null/missing day = treated as closed (never silently "open all day").
  businessHours                 Json?
  // Phase 7B-2: plain-text SMS templates for the automated reminder
  // cadence -- deliberately separate from messageTemplates above (that's
  // the composer's own manual "insert template" menu, a different
  // concept). Shape: { clientWeekBefore, clientNightBefore, clientMorningOf,
  // artistDayBefore, estimateFollowUp }, each a plain string with
  // {{placeholder}} tokens filled in at send time.
  reminderTemplates             Json?
  // Shape: { weekBeforeTime, nightBeforeTime, morningOfTime,
  // artistDayBeforeTime }, each "HH:MM" in this studio's own timezone
  // (see the `timezone` field above) -- checked against
  // isWithinSendWindow (lib/reminderWindow.ts) by the 15-minute ticker.
  reminderSendTimes             Json?
  // Package C1: configurable deposit-tier lookup, replacing the previously
  // hardcoded breakpoints in computeDepositTier (apps/api/src/routes/
  // inquiries.ts). Array<{ minAmountCents: number, maxAmountCents: number |
  // null, depositAmountCents: number }>, ordered ascending by minAmountCents;
  // maxAmountCents: null marks the top, catch-all tier -- exactly one tier
  // must have it, enforced by validateDepositTiers at PATCH time, not by
  // the schema. Nullable only because existing rows predate this column;
  // the migration backfills every existing studio with its literal prior
  // hardcoded behavior, and computeDepositTier falls back to that same
  // default list if a studio somehow still has null here.
  depositTiers                  Json?
  // Package C2: one of a fixed, curated set of theme presets (see
  // apps/api/src/lib/themePresets.ts's THEME_PRESET_KEYS) -- never
  // free-form. Default matches the current live theme's key exactly, so
  // every existing studio's appearance is unchanged until an OWNER
  // deliberately picks a different one.
  themePreset                   String   @default("onyx-lime")
  createdAt                     DateTime @default(now())
  updatedAt                     DateTime @updatedAt

  studioId String @unique
  studio   Studio @relation(fields: [studioId], references: [id])
}

// Package C1: add-your-own policy beyond the 8 fixed StudioSettings HTML
// fields -- same WYSIWYG edit pattern (RichTextEditor.tsx), same
// sanitizeHtml.ts allow-list applied on render, but an open-ended list
// instead of fixed keys. isPublic gates visibility on the public /policies
// page; a policy can exist (and be edited) while isPublic is false, it's
// just not listed there.
model CustomPolicy {
  id        String   @id @default(cuid())
  title     String
  bodyHtml  String?
  isPublic  Boolean  @default(false)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  studioId String
  studio   Studio @relation(fields: [studioId], references: [id])

  @@index([studioId])
}

model AuditLog {
  id         String   @id @default(cuid())
  entityType String
  entityId   String
  action     String
  changes    Json?
  createdAt  DateTime @default(now())

  studioId String
  studio   Studio @relation(fields: [studioId], references: [id])

  // Null actor means a public/unauthenticated or system action (e.g. a
  // client signing a public token link), not a missing/deleted user.
  actorUserId String?
  actorUser   User?   @relation(fields: [actorUserId], references: [id])

  @@index([studioId, entityType, entityId])
  @@index([studioId, createdAt])
}

model DepositForm {
  id                          String    @id @default(cuid())
  token                       String    @unique
  tokenExpiresAt              DateTime
  agreedNonRefundable         Boolean   @default(false)
  agreedLatePolicy            Boolean   @default(false)
  agreedNoShowForfeit         Boolean   @default(false)
  agreedNewDepositAfterNoShow Boolean   @default(false)
  agreedRescheduleLimit       Boolean   @default(false)
  agreedExpiration            Boolean   @default(false)
  agreedIdAndVoucher          Boolean   @default(false)
  agreedAge18                 Boolean   @default(false)
  signatureName               String?
  // Base64 PNG from signature_pad, same pattern as ConsentForm.signatureData
  // -- signatureName stays too (the typed legal name backing the drawn mark,
  // shown in the audit trail), it's just no longer the signature itself.
  signatureData               String?
  signedAt                    DateTime?
  depositAmount               Float
  feeAmount                   Float
  totalCharged                Float
  paidManually                Boolean   @default(false)
  paidAt                      DateTime?
  createdAt                   DateTime  @default(now())

  // Package D: purely informational heads-up shown on the public deposit
  // page (e.g. "tentatively scheduled for..."), staff-picked from
  // getSuggestedTimes. Deliberately has NO relation to Appointment and NO
  // gift-card requirement -- this is not a scheduling commitment, real
  // scheduling still only happens via POST /inquiries/:id/schedule after
  // the deposit is paid. Either both set or both null.
  proposedStartAt              DateTime?
  proposedEndAt                DateTime?

  inquiryId String  @unique
  inquiry   Inquiry @relation(fields: [inquiryId], references: [id])

  // One-way optional link to the gift card issued for this deposit, once
  // one exists. Nullable: older/unsigned deposit forms won't have one yet.
  giftCardId String?   @unique
  giftCard   GiftCard? @relation(fields: [giftCardId], references: [id])
}

model GiftCard {
  id          String         @id @default(cuid())
  code        String         @unique
  amountCents Int
  status      GiftCardStatus @default(ACTIVE)
  expiresAt   DateTime?
  paidAt      DateTime?
  redeemedAt  DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  studioId String
  studio   Studio @relation(fields: [studioId], references: [id])

  clientId String
  client   Client @relation(fields: [clientId], references: [id])

  // Nullable is deliberate: a card can sit unattached (purchased as an
  // actual gift, or left over after a deposit rollover) until it's used
  // toward a specific appointment.
  appointmentId String?      @unique
  appointment   Appointment? @relation(fields: [appointmentId], references: [id])

  issuedById String
  issuedBy   User   @relation(fields: [issuedById], references: [id])

  depositForm DepositForm?

  // Set only for EXEMPT cards -- an optional staff-facing note (e.g.
  // "Sponsor", "Comped -- prior service issue") explaining why the deposit
  // requirement was waived.
  exemptionReason String?

  @@index([studioId])
  @@index([clientId])
}

model LiabilityWaiver {
  id     String                @id @default(cuid())
  status LiabilityWaiverStatus @default(PENDING)

  // Public-flow bearer token (same pattern as ConsentForm) -- unlike
  // GiftCard.code, this token IS single-use: it's cleared on signing.
  token          String?   @unique
  tokenExpiresAt DateTime?

  legalName             String?
  dateOfBirth           DateTime?
  emergencyContactName  String?
  emergencyContactPhone String?
  // Array<{ questionIndex: number, answer: "YES" | "NO", explanation?: string }>
  healthAnswers         Json?
  idImageUrl            String?
  // Array<{ clauseIndex: number, initials: string }>
  clauseInitials        Json?
  signatureName         String?

  photoReleaseAccepted      Boolean @default(false)
  photoReleaseSignatureName String?

  // Snapshots of the template exactly as the client saw it at signing time,
  // so a later edit to StudioSettings' waiver template never retroactively
  // changes what a signed record shows (same immutability principle as
  // Inquiry.estimateTermsSnapshot).
  healthQuestionsSnapshot Json
  clausesSnapshot         Json
  acknowledgmentSnapshot  String?
  photoReleaseSnapshot    String?

  signedAt   DateTime?
  verifiedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  studioId String
  studio   Studio @relation(fields: [studioId], references: [id])

  clientId String
  client   Client @relation(fields: [clientId], references: [id])

  appointmentId String      @unique
  appointment   Appointment @relation(fields: [appointmentId], references: [id])

  verifiedById String?
  verifiedBy   User?   @relation("WaiverVerifiedBy", fields: [verifiedById], references: [id])

  @@index([studioId])
  @@index([clientId])
}

// Phase 6A: exactly one of clientId/staffUserId is set, matching `type`.
// Prisma can't express "exactly one of two nullable FKs" as a real
// constraint, so this is validated in the route layer (POST /conversations)
// -- noted there too.
model Conversation {
  id            String           @id @default(cuid())
  type          ConversationType
  // Denormalized for list sorting/preview without joining every message.
  lastMessageAt DateTime?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  studioId String
  studio   Studio @relation(fields: [studioId], references: [id])

  // Set iff type CLIENT. Unique: one thread per client, ever (see the
  // Client-merge handling in clients.ts for what happens when two clients
  // -- each possibly with their own thread -- become one).
  clientId String? @unique
  client   Client? @relation(fields: [clientId], references: [id])

  // Set iff type STAFF, AND stays set if the thread is later upgraded to
  // GROUP via an @mention (see ConversationParticipant) -- every GROUP
  // conversation started life as a 1:1 STAFF thread, so this becomes "which
  // staff member's original thread this group grew out of," used as a
  // lookup key by /conversations/resolve and the "+ New Chat" roster.
  // Never nulled out on upgrade.
  staffUserId String? @unique
  staffUser   User?   @relation("StaffConversation", fields: [staffUserId], references: [id])

  messages      Message[]
  reads         ConversationRead[]
  tags          ConversationTag[]
  prefillDrafts PrefillDraft[]
  participants  ConversationParticipant[]

  @@index([studioId, type, lastMessageAt])
}

// Links a conversation to a related record elsewhere in the app (that
// record's studio and, for CLIENT threads, its client are validated to
// match at the route layer -- no tagging someone else's inquiry onto a
// thread). entityType is a plain string (like AuditLog.entityType) rather
// than a Prisma enum, so a new taggable entity type never needs a migration.
model ConversationTag {
  id         String   @id @default(cuid())
  entityType String
  entityId   String
  createdAt  DateTime @default(now())

  studioId String
  studio   Studio @relation(fields: [studioId], references: [id])

  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id])

  createdById String
  createdBy   User   @relation(fields: [createdById], references: [id])

  @@unique([conversationId, entityType, entityId])
  @@index([studioId])
}

// Immutable once created -- a communications record, not an editable
// document. No PATCH/DELETE route exists for this model, deliberately.
model Message {
  id          String           @id @default(cuid())
  channel     MessageChannel
  direction   MessageDirection
  body        String
  // Array<string> of Cloudinary URLs, reusing the existing upload flow.
  attachments Json?
  // Set at creation only (messages stay immutable) -- null for ordinary
  // messages. Phase 6B's sanitized share-to-artist sets
  // { kind: "shared_inquiry", inquiryId } so the UI can render a distinct
  // card instead of a plain text bubble.
  metadata    Json?
  createdAt   DateTime         @default(now())

  studioId String
  studio   Studio @relation(fields: [studioId], references: [id])

  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id])

  // The staff member who wrote/logged this message. Null is reserved for a
  // future auto-ingested inbound message (e.g. a real IG/SMS webhook) --
  // in this phase every message is logged by a staff member, so it's
  // always set.
  authorUserId String?
  author       User?   @relation("MessageAuthor", fields: [authorUserId], references: [id])

  @@index([conversationId, createdAt])
  @@index([studioId])
}

// A server-stored draft of intake-form field values, handed to the public
// intake form via a capability token in the URL -- never the field values
// themselves, so no PII ever rides in a query string. Populated either
// manually by staff (POST /prefill-drafts) or from the Claude-assisted
// draft-inquiry flow. One-time use: usedAt is set on the inquiry submission
// that consumes it, same expire-and-single-use shape as the deposit/waiver
// tokens elsewhere in this app.
model PrefillDraft {
  id        String    @id @default(cuid())
  token     String    @unique
  // Intake-form field values only (contact + tattoo fields) -- shape
  // mirrors a subset of Inquiry's own fields, validated at the route layer.
  payload   Json
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  studioId String
  studio   Studio @relation(fields: [studioId], references: [id])

  createdById String
  createdBy   User   @relation(fields: [createdById], references: [id])

  // Set when generated from a specific conversation (the Claude-assisted
  // flow); null for a plain manual prefill link with no originating thread.
  conversationId String?
  conversation   Conversation? @relation(fields: [conversationId], references: [id])

  @@index([studioId])
}

// One row per (conversation, user) tracking when that user last read it.
// Missing row means "never read" -- every message counts as unread. Not
// audited: same deliberate noise-exception as SectionSeen (Phase 5) --
// reading a thread happens on every open and carries no business meaning.
model ConversationRead {
  id         String   @id @default(cuid())
  lastReadAt DateTime @default(now())

  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id])

  userId String
  user   User   @relation(fields: [userId], references: [id])

  @@unique([conversationId, userId])
}

// Membership for GROUP conversations (a STAFF 1:1 thread upgraded in place
// when someone @mentions a new person into it -- see POST /:id/messages).
// CLIENT and un-upgraded STAFF threads have no rows here; identity for
// those still comes from clientId/staffUserId.
model ConversationParticipant {
  id      String   @id @default(cuid())
  addedAt DateTime @default(now())

  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id])

  userId String
  user   User   @relation(fields: [userId], references: [id])

  @@unique([conversationId, userId])
}

// Phase 5: system tasks are DERIVED live from current data state (see
// apps/api/src/lib/tasks/), never materialized into rows. This is the only
// row that exists per system task, and only once a user dismisses it --
// absence of a row means "not dismissed," not "doesn't exist."
//
// entityId is normally just the underlying record's id, but for task types
// whose "identity" can be refreshed by a real business event (e.g.
// ESTIMATE_FOLLOWUP after a resend), the source encodes that event's
// timestamp into entityId (e.g. "{inquiryId}:{estimateSentAt}") so a fresh
// send produces a fresh, undismissed key rather than staying silently
// dismissed forever. See apps/api/src/lib/tasks/estimateFollowup.ts.
model TaskDismissal {
  id          String   @id @default(cuid())
  taskType    String
  entityId    String
  dismissedAt DateTime @default(now())

  studioId String
  studio   Studio @relation(fields: [studioId], references: [id])

  userId String
  user   User   @relation(fields: [userId], references: [id])

  @@unique([userId, taskType, entityId])
  @@index([studioId])
}

// Real rows (unlike system tasks) -- a personal to-do belongs to exactly
// one user (the assignee, userId) but may have been created BY someone
// else (UI-1: OWNER/FRONT_DESK assigning a task to a teammate). Assignee-
// only completion; creator or assignee can delete.
model PersonalTask {
  id          String    @id @default(cuid())
  title       String
  notes       String?
  dueAt       DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  studioId String
  studio   Studio @relation(fields: [studioId], references: [id])

  // The assignee -- whoever's "Assigned to Me" list this shows up in.
  userId String
  user   User   @relation(fields: [userId], references: [id])

  // Who created it. Equal to userId for a self-created task; different
  // when OWNER/FRONT_DESK assigned it to a teammate.
  createdById String
  createdBy   User   @relation("PersonalTaskCreatedBy", fields: [createdById], references: [id])

  @@index([studioId])
  @@index([userId])
}

// One row per (user, nav section) tracking when that user last looked.
// Missing row / null lastSeenAt means "never seen" -- count everything.
model SectionSeen {
  id         String   @id @default(cuid())
  section    String
  lastSeenAt DateTime @default(now())

  studioId String
  studio   Studio @relation(fields: [studioId], references: [id])

  userId String
  user   User   @relation(fields: [userId], references: [id])

  @@unique([userId, section])
}

// Phase 7A scheduler foundation. One row per (jobName, scheduledFor) slot --
// deliberately studio-agnostic (a job iterates every studio internally; see
// each job's own comments in apps/api/src/lib/jobs/). The unique constraint
// IS the double-run guard: a job claims its slot with a `create` before
// doing any work, so a second process (or a manual run-now landing on the
// same instant another tick already claimed) hits a unique violation and
// is skipped rather than re-running the work -- see runJob in
// apps/api/src/lib/jobs/registry.ts.
model JobRun {
  id           String    @id @default(cuid())
  jobName      String
  scheduledFor DateTime
  startedAt    DateTime  @default(now())
  finishedAt   DateTime?
  status       JobStatus @default(RUNNING)
  // Counts of what the run did (e.g. { cardsExpired: 3 }) -- shape is
  // per-job, not modeled here.
  details      Json?
  error        String?

  @@unique([jobName, scheduledFor])
  @@index([jobName, scheduledFor])
}

// Phase 7B-2: the artist day-before digest is one consolidated message per
// artist per day (not per-appointment), so its dedup can't live on
// Appointment the way the client cadence's does -- it needs its own record
// keyed by (artist, the date being reminded about).
model ArtistReminderLog {
  id      String   @id @default(cuid())
  forDate DateTime
  sentAt  DateTime @default(now())

  studioId String
  studio   Studio @relation(fields: [studioId], references: [id])

  artistId String
  artist   Artist @relation(fields: [artistId], references: [id])

  @@unique([artistId, forDate])
}

// Shortens every outbound-SMS-bound public link (estimate/deposit/waiver/
// gift-card/intake/prefill) so a text doesn't arrive as a 70+ character
// raw URL. Deliberately keyed by targetUrl (not by which entity it points
// to) and looked up idempotently in lib/shortLinks.ts -- the same long URL
// always resolves to the same short code, so re-rendering a link that's
// already been shortened once (e.g. a waiver link reused across the
// week-before/night-before/morning-of reminder cadence) never mints a
// second one. No expiry of its own: the destination page's own token
// already carries whatever expiry applies, so an old short link just
// forwards to a page that correctly reports itself expired.
model ShortLink {
  id        String   @id @default(cuid())
  code      String   @unique
  targetUrl String
  createdAt DateTime @default(now())

  @@index([targetUrl])
}
