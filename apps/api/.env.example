# Copy this file to `.env` and fill in real values for local development.
# See DEVELOPMENT.md for the full dev-vs-production environment convention.

# Development database only. NEVER point this at production -- the prod
# connection string lives in .env.production (gitignored, not this file),
# and is used only for deliberate release steps (`prisma migrate deploy`,
# read-only sanity checks), never for day-to-day dev/test work.
DATABASE_URL="postgresql://postgres:password@localhost:5432/ink_manager_dev"

# Generate real secrets for anything beyond local dev:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="replace-with-a-generated-secret"

# Guards POST /studios/bootstrap. Never expose this route publicly.
BOOTSTRAP_SECRET="replace-with-a-generated-secret"

# Base URL of the web app, used to build consent-form/estimate/deposit/waiver
# signing links.
FRONTEND_URL="http://localhost:5173"

# Cloudinary media storage
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# Anthropic API key for Claude-assisted inquiry drafting (POST
# /conversations/:id/draft-inquiry). Called from this server only -- never
# expose this key to the frontend. Get one at console.anthropic.com.
ANTHROPIC_API_KEY="sk-ant-replace-with-a-real-key"
